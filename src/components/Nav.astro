---
import { ACQUISITION_MAILTO } from '../consts';
---

<nav id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-x-3 no-underline">
        <div class="w-9 h-9 rounded-2xl bg-gradient-to-br from-[#22f5ff] via-[#a855f7] to-[#22f5ff] p-px">
          <div class="w-full h-full bg-[#0a0a0f] rounded-2xl flex items-center justify-center">
            <span class="text-[#22f5ff] text-lg font-bold tracking-tighter">AI</span>
          </div>
        </div>
        <div>
          <span class="font-display text-2xl font-semibold tracking-tighter text-white">ailegalguard.com</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-x-9 text-sm font-medium">
        <a href="#positioning" class="nav-link text-white/80 no-underline">The Positioning</a>
        <a href="#why" class="nav-link text-white/80 no-underline">Why This Domain</a>
        <a href="#uses" class="nav-link text-white/80 no-underline">Ideal For</a>
        <a href="#pricing" class="nav-link text-white/80 no-underline">Pricing</a>
      </div>

      <!-- CTA Buttons -->
      <div class="flex items-center gap-x-3">
        <a href="#inquire"
           class="hidden sm:inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold rounded-2xl border border-white/20 hover:bg-white/5 transition-colors no-underline text-white/80">
          Inquire
        </a>
        <a href={ACQUISITION_MAILTO}
           class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold rounded-2xl bg-white text-[#0a0a0f] hover:bg-white/90 transition-all active:scale-[0.985] no-underline">
          Secure Now
        </a>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn"
                class="md:hidden w-10 h-10 flex items-center justify-center text-white/70 hover:text-white bg-transparent border-0 cursor-pointer"
                aria-label="Toggle menu">
          <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>

<!-- Mobile Menu -->
<div id="mobile-menu" class="hidden md:hidden fixed inset-0 z-40 bg-[#0a0a0f] pt-20">
  <div class="px-6 py-8 flex flex-col gap-y-6 text-lg font-medium">
    <a href="#positioning" class="py-2 text-white/80 no-underline">The Positioning</a>
    <a href="#why" class="py-2 text-white/80 no-underline">Why This Domain</a>
    <a href="#uses" class="py-2 text-white/80 no-underline">Ideal For</a>
    <a href="#pricing" class="py-2 text-white/80 no-underline">Pricing</a>
    <div class="pt-4 border-t border-white/10">
      <a href={ACQUISITION_MAILTO} class="block w-full text-center py-3.5 rounded-2xl bg-white text-[#0a0a0f] font-semibold no-underline">Secure This Domain</a>
    </div>
  </div>
</div>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav.classList.add('nav-scrolled');
    } else {
      nav.classList.remove('nav-scrolled');
    }
  });

  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  mobileBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden');

    if (isOpen) {
      menuIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />`;
    } else {
      menuIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6h12v12z" />`;
    }
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      menuIcon!.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />`;
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !mobileMenu?.classList.contains('hidden')) {
      mobileMenu.classList.add('hidden');
      menuIcon!.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />`;
    }
  });
</script>
